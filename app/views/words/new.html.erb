<div class = "container">
  <div class = "page-header">
    <h1>単語新規登録</h1>
    <%= link_to "←一覧に戻る", words_path, class: "btn btn-secondary" %>
  </div>
  <%= form_with model: @word, local: true, data: { turbo: false }, html: {multipart: true} do |f| %>
    <% if @word.errors.any? %>
      <div class="error-box">
        <h3><%=pluralize(@word.errors.count, "エラー") %>が発生しました：</h3>
        <ul>
          <% @word.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <%end%>
        </ul>
      </div>
    <%end%>
    <div class = "form-section">
      <h2>基本情報</h2>
      <div class="form-row">
        <div class="form-group">
          <%= f.label :japanese, "単語*" %>
          <%= f.text_field :japanese, class: "form-control",placeholder: "犬" %>
        </div>
        <div class = "form-group">
          <%= f. label :reading, "読み"%>
          <%= f.text_field :reading, class: "form-control", placeholder: "いぬ" %>
        </div>
      </div>
      <div class="form-group">
        <%= f.label :english, "意味*" %>
        <%= f.text_field :english, class: "form-control", placeholder: "dog" %>
      </div>
    </div>
    
    
    
<div class="form-section">
  <h2>画像</h2>

  <div class="form-group">
    <%= f.file_field :image, accept: "image/*", class: "form-control" %>
    <small class="form-text">JPEG,PNG,GIF形式(最大5MB)</small>





    
  </div>
  <div style = "display:grid; grid-template-columns: 1fr 1fr; gap: 20px; align-items: center;">
  
  <div style = "border: 2px solid #e0e0e0; border-radius: 8px; padding: 20px; background-color:#f9f9f9; flex-direction: column; justify-content: center; align-items: center; min-height: 250px;">
    <h4 style = "margin-top: 0; color: #333;">AI画面生成</h4>
    <p style = "color: #666; text-align: center; font-size: 14px; margin-bottom: 15px;">プロインプと入力して<br>画面を自動生成</p>
  
  <% if current_user.can_generate_image? %>
         <button type="button" id="open-ai-modal" class="btn btn-primary" style="padding: 10px 20px; font-size: 16px; display: block; margin: 0 auto;">
         生成する
        </button>
        <small style = "color: #999; margin-top: 10px;">
        残りクレジット: <span id="credits-count"><%= current_user.image_credits %></span>
        </small>

  <% else %>
     <button type="button" id="open-ai-modal" class="btn btn-primary" style="padding: 10px 20px; font-size: 16px; display: block; margin: 0 auto;" disabled="disabled" color: #999;>
         クレジット不足
      </button>
  <% end %>
  </div>
  
  <div id="confirmed-preview" style= "border:2px solid #e0e0e0; border-radius: 8px; padding: 20px; background-color:#f9f9f9; display:none; flex-direction: column; justify-content: center; align-items: center; min-height: 250px;">
    <h4 style = "margin-top: 0; color: #333;">選択済み画像</h4>
    <img id="confirmed-img" src="" alt="選択済み画像" style="max-width: 100%; max-height: 150px; object-fit: contain; margin: 15px 0; border-radius: 4px;">
    <button type="button" id="remove-confirmed" class="btn btn-secondary btn-sm">
      🗑️ 削除
    </button>
    
  </div>

  <%# hidden field %>
  <%= f.hidden_field :ai_image_url, id: "ai-image-url-field" %>
</div>


<div id="ai-modal" class="modal-overlay" style="display: none;">
  <div class="modal-content">
    <div class="modal-header">
      <h3>AI画像生成</h3>
      <button type="button" id="close-modal" class="modal-close">&times;</button>
    </div>

    <div class="modal-body">
      <%# プロンプト入力 %>
      <div class="form-group">
        <label>プロンプト</label>
        <input type="text"
               id="ai-prompt"
               class="form-control"
               placeholder="例：かわいい犬のイラスト">
      </div>

      <button type="button" id="generate-btn" class="btn btn-primary">
        生成する
      </button>

      <div id="ai-loading" style="display: none;">
        <p>画像を生成中です...</p>
      </div>

      <div id="ai-preview" style="display: none;">
        <img id="ai-preview-img" src="" alt="AI生成画像" style="max-width: 100%;">
        <div class="ai-preview-actions">
          <button type="button" id="accept-btn" class="btn btn-primary">
            この画像を使う
          </button>
          <button type="button" id="regenerate-btn" class="btn btn-secondary">
            再生成（クレジット1消費）
          </button>
        </div>
      </div>
    </div>
  </div>
</div>





    <div class="form-section">
      <h2>タグ(複数選択可)</h2>
      <div class = "tag-checkboxes">
        <%= f.collection_check_boxes :word_tag_ids, @word_tags, :id, :name do |b|%>
          <div class = "tag-checkboxes">
            <%= b.check_box%>
            <%= b.label do %>
              <span class="tag-badge" style="background-color: <%= b.object.color%>" >
                <%= b.object.name %>
              </span>
            <%end%>
          </div>
        <%end%>
      </div>
      <% if @word_tags.empty? %>
        <p>タグが登録されていません。<%= link_to "タグ管理へ", new_word_tag_path, class: "btn btn-link" %></p>
      <%end%>
    </div>
    <div class="form-section">
      <h2>類義語(複数登録可)</h2>
      <div id = "synonyms-fields">
        <%= f.fields_for :synonyms do |synonym_form| %>
          <div class= "synonym-field">
            <%= synonym_form.text_field :synonym_word, class: "form-control",placeholder: "類義語を入力" %>
          </div>
        <%end%>
      </div>
      <button type = "button" id = "add-synonym" class = "btn btn-secondary btn-sm">
        + 類義語を追加
      </button>
    </div>
    <div class= "form-actions">
      <%= f.submit "登録", class: "btn btn-primary btn-large" %>
      <%= link_to "キャンセル", words_path, class: "btn btn-secondary"%>
    </div>
  <%end%>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function() {
      const addSynonymBtn = document.getElementById('add-synonym')
      const synonymsContainer = document.getElementById('synonyms-fields')


      if(addSynonymBtn && synonymsContainer){
        addSynonymBtn.addEventListener('click', function(){
          const time = new Date().getTime();
          const newField = document.createElement('div');
          newField.className = 'synonym-field';
          newField.innerHTML = `
           <input type = "text" name = "word[synonyms_attributes][${time}][synonym_word]" class = "form-control" placeholder = "類義語を入力">`
          synonymsContainer.appendChild(newField);
        });
      }
    const modal         = document.getElementById("ai-modal");
  const openBtn       = document.getElementById("open-ai-modal");
  const closeBtn      = document.getElementById("close-modal");
  const generateBtn   = document.getElementById("generate-btn");
  const regenerateBtn = document.getElementById("regenerate-btn");
  const acceptBtn     = document.getElementById("accept-btn");
  const promptInput   = document.getElementById("ai-prompt");
  const preview       = document.getElementById("ai-preview");
  const previewImg    = document.getElementById("ai-preview-img");
  const hiddenField   = document.getElementById("ai-image-url-field");
  const loading       = document.getElementById("ai-loading");
  const creditsCount  = document.getElementById("credits-count");
  const confirmedArea = document.getElementById("confirmed-preview");
  const confirmedImg  = document.getElementById("confirmed-img");
  const removeBtn     = document.getElementById("remove-confirmed");

  // モーダル要素がなければスキップ（クレジット0でボタンがない場合）
  if (!openBtn || !modal) return;

  // ── モーダル開閉 ──
  openBtn.addEventListener("click", function () {
    modal.style.display   = "flex";
    preview.style.display = "none";
    loading.style.display = "none";
  });

  closeBtn.addEventListener("click", function () {
    modal.style.display = "none";
  });

  modal.addEventListener("click", function (e) {
    if (e.target === modal) modal.style.display = "none";
  });

  async function generateImage() {
    const prompt = promptInput.value.trim();
    if (!prompt) {
      alert("プロンプトを入力してください");
      return;
    }

    generateBtn.disabled   = true;
    regenerateBtn.disabled = true;
    loading.style.display  = "block";
    preview.style.display  = "none";

    try {
      const resp = await fetch("/words/generate_image", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content
        },
        body: JSON.stringify({ prompt: prompt })
      });

      const data = await resp.json();

      if (data.success) {
        previewImg.src             = data.image_url;
        previewImg.dataset.tempUrl = data.image_url;
        preview.style.display      = "block";
        creditsCount.textContent   = data.credits_remaining;

        if (data.credits_remaining <= 0) {
          regenerateBtn.disabled  = true;
          regenerateBtn.textContent = "再生成（クレジットなし）";
        }
      } else {
        alert(data.error || "画像生成に失敗しました");
      }
    } catch (e) {
      alert("通信エラーが発生しました");
    } finally {
      generateBtn.disabled  = false;
      loading.style.display = "none";
      if (creditsCount.textContent !== "0") {
        regenerateBtn.disabled = false;
      }
    }
  }

  generateBtn.addEventListener("click", generateImage);
  regenerateBtn.addEventListener("click", generateImage);


acceptBtn.addEventListener("click", function () {
    const url = previewImg.dataset.tempUrl;
    if (!url) return;

    hiddenField.value           = url;
    confirmedImg.src            = url;
    confirmedArea.classList.add("active")
    modal.style.display         = "none";
  });

  removeBtn.addEventListener("click", function () {
    hiddenField.value           = "";
    confirmedImg.src            = "";
    confirmedArea.classList.remove("active")
  });
});
  </script>
